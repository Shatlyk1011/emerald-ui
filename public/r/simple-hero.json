      "type": "registry:component",
      "content": "'use client'\n\n/**\n * @author: @emerald-ui\n * @description: Simple ready to use hero section\n * @version: 1.0.0\n * @date: 2026-02.26\n * @license: MIT\n * @website: https://emerald-ui.com\n */\n\nimport { useState } from 'react'\nimport Link from 'next/link'\n\nconst links = [\n  { title: 'Home', href: '#' },\n  { title: 'Team', href: '#' },\n  { title: 'About', href: '#' },\n  { title: 'Products', href: '#' },\n]\n\nconst Header = () => {\n  const [open, setOpen] = useState(false)\n\n  return (\n    <header className='flex h-20 w-full items-center justify-between px-4 lg:px-6 xl:px-10'>\n      <div className='z-40 mb-4 text-sm text-white md:text-base lg:mb-0'>\n        Logo\n      </div>\n      <button\n        onClick={() => setOpen(!open)}\n        type='button'\n        className='z-[103] block lg:hidden'\n      >\n        {open ? (\n          <svg\n            focusable='false'\n            className='fill-white'\n            width={24}\n            height={24}\n            aria-hidden='true'\n            viewBox='0 0 24 24'\n          >\n            <path d='M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z'></path>\n          </svg>\n        ) : (\n          <svg\n            focusable='false'\n            className='fill-white'\n            width={24}\n            height={24}\n            aria-hidden='true'\n            viewBox='0 0 24 24'\n          >\n            <path d='M3 18h18v-2H3zm0-5h18v-2H3zm0-7v2h18V6z'></path>\n          </svg>\n        )}\n      </button>\n      <nav\n        className={`absolute top-0 right-0 z-102 mx-0 flex h-full w-60 flex-col items-center justify-start space-y-6 bg-neutral-950 py-10 text-lg text-white transition-all duration-200 lg:relative lg:h-auto lg:w-auto lg:flex-row lg:justify-between lg:space-y-0 lg:space-x-4 lg:bg-transparent lg:py-0 lg:text-base xl:text-lg ${open ? 'pointer-events-auto visible translate-x-[0%] opacity-100 select-auto' : 'pointer-events-none invisible translate-x-full opacity-0 select-none lg:pointer-events-auto lg:visible lg:translate-x-[0%] lg:opacity-100 lg:select-auto'}`}\n      >\n        <ul className='flex flex-col items-start gap-2 *:cursor-pointer lg:flex-row lg:items-center lg:space-x-6'>\n          {links.map(({ title, href }) => (\n            <Link\n              key={title}\n              href={href}\n              className={`hover:text-slate-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-600 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-600`}\n            >\n              {title}\n            </Link>\n          ))}\n        </ul>\n      </nav>\n      <div\n        onClick={() => setOpen(!open)}\n        className={`${open ? 'absolute' : 'hidden'} top-0 left-0 z-101 h-full w-full lg:hidden dark:bg-black/50`}\n      ></div>\n    </header>\n  )\n}\n\nconst SimpleHero = () => {\n  return (\n    <main className='relative z-10 h-200 w-full overflow-hidden'>\n      <Header />\n      <section className='w-full'>\n        <img\n          src='https://images.unsplash.com/photo-1464822759023-fed622ff2c3b'\n          className='absolute top-0 left-0 h-full w-full object-cover object-top'\n          alt='mountains view'\n        />\n        <div className='absolute top-0 left-0 z-20 h-full w-full bg-gradient-to-b from-black/90 to-black/60'></div>\n\n        <div className='relative z-100 flex h-full justify-center pt-48 text-white'>\n          <div className='max-w-[90%] items-center text-center font-medium lg:max-w-[75%]'>\n            <p className='leading-none max-sm:text-xl lg:text-2xl'>\n              Experience the Heights\n            </p>\n            <h1 className='my-2.5 text-4xl font-black lg:my-4 lg:text-5xl'>\n              Majestic Mountain Peaks\n            </h1>\n            <p className='mt-2.5 text-base leading-[150%] text-balance opacity-80 lg:text-xl'>\n              Embark on an unforgettable journey through the world. Lorem ipsum\n              dolor sit amet consectetur adipisicing elit. Dignissimos ipsum,\n              distinctio voluptatibus assumenda ut in voluptatem!\n            </p>\n          </div>\n        </div>\n      </section>\n    </main>\n  )\n}\n\nexport default SimpleHero\n",
      "path": "/components/emerald-ui-components/hero/simple-hero.tsx",
      "target": "components/ui/simple-hero.tsx"
    }
  ]
}