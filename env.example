# Core Application Settings
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database Configuration (MongoDB)
# Connection string for your MongoDB cluster
DATABASE_URI=""

# Payload CMS Configuration
# Secret key used for cryptographic operations in Payload CMS
PAYLOAD_SECRET=""

# Authentication (Supabase)
# Core credentials for the Supabase client
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Email Service (Plunk / SMTP)
# Refer to Plunk documentation for configuring SMTP services
SMTP_FROM="noreply@yourdomain.com"
SMTP_PASSWORD=""

# Analytics Tracking
# PostHog configuration for user tracking and events
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=""

# Cloudflare R2 Storage
# Credentials and bucket configuration for R2 file storage
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT_URL=""
R2_CUSTOM_DOMAIN=""

# Environment bucket names
R2_IMAGES_BUCKET="images"
R2_VIDEOS_BUCKET="videos"
R2_FAVICONS_BUCKET="favicons"

# Third-party Integrations
# API Token for Scrnify, used to generate dynamic website screenshots
# Documentation: https://scrnify.com/
SCRIFY_TOKEN=""